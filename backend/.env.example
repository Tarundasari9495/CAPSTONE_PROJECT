# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/contract_analyzer
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─────────────────────────────────────────────────────────────
# AI / LLM
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LITELLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-large

# ─────────────────────────────────────────────────────────────
# Vector Store
# ─────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ─────────────────────────────────────────────────────────────
# File Upload
# ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20

# ─────────────────────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-256-bit-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ─────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173
